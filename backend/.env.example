# =============================================================================
# Copy to .env and fill values. Never commit .env.
# On Railway: add the SAME keys in Project → Variables (no file upload).
# =============================================================================

# Server
NODE_ENV=development
PORT=5000
# Behind Railway / reverse proxy — required for accurate client IP in rate limits
# TRUST_PROXY=1
# API_RATE_LIMIT_MAX=280          # requests per IP per 15 min (default 280 prod, 500 dev)
# AUTH_RATE_LIMIT_MAX=40          # login/register/forgot/reset POSTs per IP per 15 min (default 40 prod, 80 dev)
# BOT_RATE_LIMIT_MAX=45           # stricter cap for script-like User-Agents (curl, python-requests, …)
# BOT_RATE_LIMIT_WINDOW_MS=900000
# BOT_THROTTLE_ENABLED=false      # disable script-UA throttle (e.g. load testing)
# MAX_INPUT_DEPTH_QUERY=8
# MAX_INPUT_DEPTH_BODY=14

# Logging (Winston): error | warn | info | verbose | debug | silly
# LOG_LEVEL=debug
# LOG_TO_FILE=0          # set on read-only disks (skip logs/error.log + combined.log)
# LOG_HEALTH=1           # log /api/health hits (default: skipped)
# LOG_SERVICE_NAME=maison-elara-api

# In-memory HTTP response cache (public GET JSON for products, categories, settings, colors)
# CACHE_ENABLED=false       # disable caching entirely
# CACHE_MAX_ENTRIES=5000
# CACHE_TTL_PRODUCTS_MS=45000
# CACHE_TTL_CATEGORIES_MS=120000
# CACHE_TTL_SETTINGS_MS=60000
# CACHE_TTL_COLORS_MS=300000

# Public URL of THIS API (no trailing slash)
# Local: http://localhost:5000
# Railway: https://YOUR-SERVICE.up.railway.app  OR  https://api.yourdomain.com
# Required for: Google OAuth callback, Telegram setWebhook
BACKEND_URL=http://localhost:5000

# MongoDB (required — app exits if missing)
# Atlas: Network Access → allow 0.0.0.0/0 (or your host’s egress IPs). Paused cluster = timeouts.
# If logs show "secureConnect timed out" / MongoServerSelectionError, redeploy after DB config fixes;
# the app also sets family:4 (IPv4) to avoid broken IPv6 routes from Docker/Railway.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/maison-elara

# Admin user — used by `npm run seed` (defaults below) and optional `npm run create-admin`
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_me_strong_password
# ADMIN_FIRST_NAME=Admin
# ADMIN_LAST_NAME=User

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# Cloudflare Images + Stream (uploads)
# API token: Account → API Tokens — include Account.Cloudflare Images:Edit and Account.Cloudflare Stream:Edit
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_api_token_with_images_and_stream
# Images delivery hash (Dashboard → Images → Developer Resources). Fallback if upload response has no variant URLs.
# CLOUDFLARE_IMAGES_ACCOUNT_HASH=your_imagedelivery_hash

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Email — Resend (HTTPS API, no SMTP port needed — works on Railway free plan)
# Sign up free at https://resend.com → get API key
# Add your domain (yf14.store) in Resend dashboard → add DNS records in Cloudflare
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=YF14 Store <orders@yf14.store>
# Where store owner receives copies of order emails (BCC)
EMAIL_USER=your_email@gmail.com
# Optional override for BCC (defaults to EMAIL_USER)
ORDER_NOTIFY_EMAIL=

# -----------------------------------------------------------------------------
# Telegram — set ALL of these on Railway or Approve/Decline + new orders break
# -----------------------------------------------------------------------------
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA...your_bot_token
# Group or channel ID where order notifications go (often negative for groups)
TELEGRAM_CHAT_ID=-1001234567890
# Random secret — used to protect GET /api/telegram/set-webhook?secret=...
TELEGRAM_WEBHOOK_SECRET=generate_a_long_random_string

# Frontend URL (CORS, email links)
# Comma-separated for multiple sites. In development, localhost / 127.0.0.1 on any port is allowed automatically.
FRONTEND_URL=http://localhost:3000

# Admin (seed script)
ADMIN_EMAIL=admin@maisonelara.com
ADMIN_PASSWORD=Admin@123456

# Store logo (MongoDB StoreSettings + Cloudflare Images)
# Public: GET /api/settings → { logoUrl }
# Admin UI: /admin/settings  OR  POST /api/upload/store-logo (multipart field: logo)
# CLI: node scripts/seed-store-logo.js path/to/logo.png
