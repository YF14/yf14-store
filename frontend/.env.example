# =============================================================================
# Copy to .env.local for local dev. On Vercel/Railway: set in dashboard.
# NEXT_PUBLIC_* vars are exposed to the browser — never put secrets there.
# =============================================================================

# Google Analytics 4 + Meta Pixel (optional — leave unset to disable)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXX

# Backend API base (must include /api)
# Local:
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Production (example):
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api

# Maintenance / API availability (optional)
# In production, the app pings GET {NEXT_PUBLIC_API_URL}/health on load. If it fails, a maintenance screen is shown.
# Force maintenance UI even when the API is up (deployments / planned downtime):
# NEXT_PUBLIC_MAINTENANCE_MODE=1
# Disable automatic health gate in production (emergency only):
# NEXT_PUBLIC_MAINTENANCE_GATE=0
# Enable the health gate in development (to test the maintenance screen):
# NEXT_PUBLIC_MAINTENANCE_GATE=1

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Optional — shown in footer phone icon (tel: link). If unset, icon links to /contact.
# NEXT_PUBLIC_STORE_PHONE=+9647700000000

# WhatsApp chat link (digits only, country code included). Footer "WhatsApp us" uses https://wa.me/{number}
NEXT_PUBLIC_WHATSAPP_NUMBER=9647750771777

# Facebook page (footer + contact). Optional display text for contact card:
# NEXT_PUBLIC_FACEBOOK_DISPLAY=facebook.com/yf14store
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/yf14store

# Optional: exact Stream customer hostname if next/image rejects thumbnails (from a Stream thumbnail URL)
# Example: customer-abc123.cloudflarestream.com
# NEXT_PUBLIC_CF_STREAM_CUSTOMER_HOST=customer-abc123.cloudflarestream.com

# Site URL (metadata, absolute links)
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_SITE_URL=https://your-frontend.vercel.app

# Legacy / optional if your UI still references Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
