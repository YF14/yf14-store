# =============================================================================
# Copy to .env.local for local dev. On Vercel/Railway: set in dashboard.
# NEXT_PUBLIC_* vars are exposed to the browser — never put secrets there.
# =============================================================================

# Backend API base (must include /api)
# Local:
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Production (example):
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Optional — shown in footer phone icon (tel: link). If unset, icon links to /contact.
# NEXT_PUBLIC_STORE_PHONE=+9647700000000

# WhatsApp chat link (digits only, country code included). Footer "WhatsApp us" uses https://wa.me/{number}
# NEXT_PUBLIC_WHATSAPP_NUMBER=9647700000000

# Site URL (metadata, absolute links)
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_SITE_URL=https://your-frontend.vercel.app

# Legacy / optional if your UI still references Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
